REMOTE_PY = """\
# remote.py
import threading
from evdev import InputDevice, ecodes, list_devices

class PS5Controller:
    def __init__(self):
        self.state = {
            'left_stick_x': 0.0, 'left_stick_y': 0.0, 'right_stick_x': 0.0,
            'quadruped_strafe': False, 'emergency_stop': False
        }
        self.lock = threading.Lock()
        self.device = None

        for path in list_devices():
            try:
                dev = InputDevice(path)
                if any(x in dev.name.lower() for x in ["wireless controller", "dualsense", "gamepad"]):
                    self.device = dev
                    print(f"[REMOTE] Paired to: {dev.name}")
                    break
            except Exception:
                pass

    def _normalize_axis(self, value, min_val=0, max_val=255):
        center = (max_val + min_val) / 2.0
        span = (max_val - min_val) / 2.0
        normalized = (value - center) / span
        return normalized if abs(normalized) > 0.1 else 0.0

    def _loop(self):
        if not self.device: return
        try:
            for event in self.device.read_loop():
                with self.lock:
                    if event.type == ecodes.EV_ABS:
                        if event.code == ecodes.ABS_X:
                            self.state['left_stick_x'] = self._normalize_axis(event.value)
                        elif event.code == ecodes.ABS_Y:
                            self.state['left_stick_y'] = -self._normalize_axis(event.value)
                        elif event.code == ecodes.ABS_RX:
                            self.state['right_stick_x'] = self._normalize_axis(event.value)
                    elif event.type == ecodes.EV_KEY:
                        if event.code == ecodes.BTN_TL:
                            self.state['quadruped_strafe'] = bool(event.value)
                        elif event.code in [ecodes.BTN_NORTH, ecodes.BTN_WEST]:
                            self.state['emergency_stop'] = True
        except Exception as e:
            print(f"[REMOTE] Disconnected: {e}")

    def start(self):
        threading.Thread(target=self._loop, daemon=True).start()

    def get_state(self):
        with self.lock: return dict(self.state)
"""

